# Project River — 1Password-backed environment file.
#
# Every value is an `op://` reference that resolves at runtime via
# `op run --env-file=scripts/env-op.env -- <command>` or
# `eval $(op inject -i scripts/env-op.env)`.
#
# The operator must be signed in to 1Password CLI (`op signin`) and have
# access to the "River" vault populated by scripts/op-setup.sh.
#
# NOTE: This file contains NO secrets and IS safe to commit.

# ---- Paperclip ----
PAPERCLIP_URL=op://River/River Paperclip/url
PAPERCLIP_API_URL=op://River/River Paperclip/url
PAPERCLIP_SESSION_COOKIE=op://River/River Paperclip/Session Cookie
PAPERCLIP_IMAGE_DIGEST=op://River/River Paperclip/Image Digest

# ---- CBS Supabase ----
SUPABASE_URL=op://River/River CBS Supabase/url
SUPABASE_SERVICE_ROLE_KEY=op://River/River CBS Supabase/Service Role Key

# ---- WR Supabase ----
WR_SUPABASE_URL=op://River/River WR Supabase/url
WR_SUPABASE_SERVICE_ROLE_KEY=op://River/River WR Supabase/Service Role Key
WR_SUPABASE_DB_PASSWORD=op://River/River WR Supabase/DB Password

# ---- Limited Supabase role (for agent read paths) ----
RIVER_AGENT_READ_PASSWORD=op://River/River Agent Read/password

# ---- LLM + embeddings ----
VOYAGE_API_KEY=op://River/River Voyage AI/credential
ANTHROPIC_API_KEY=op://River/River Anthropic/credential

# ---- Microsoft Graph ----
MICROSOFT_CLIENT_ID=op://River/River Microsoft Graph/Client ID
MICROSOFT_CLIENT_SECRET=op://River/River Microsoft Graph/Client Secret
MICROSOFT_TENANT_ID=op://River/River Microsoft Graph/Tenant ID

# ---- Xero ----
XERO_CLIENT_ID=op://River/River Xero/Client ID
XERO_CLIENT_SECRET=op://River/River Xero/Client Secret

# ---- GitHub ----
GITHUB_PAT=op://River/River GitHub PAT/credential

# ---- Teams / Power Automate webhook ----
TEAMS_WEBHOOK_URL=op://River/River Teams Webhook/credential

# ---- CA Sender (Apps Script) ----
RIVER_CA_SENDER_TOKEN=op://River/River CA Sender/Shared Token
RIVER_CA_SENDER_URL=op://River/River CA Sender/Web App URL

# ---- WR Google Cloud ----
WR_GCP_PROJECT_ID=op://River/River WR GCP/Project ID
WR_SERVICE_ACCOUNT_EMAIL=op://River/River WR GCP/Service Account Email
WR_DRIVE_ID=op://River/River WR GCP/Drive ID
# Service account JSON is attached as a document inside the 1Password item.
# Scripts that need the file on disk should download it at runtime:
#   op document get "River WR GCP Service Account JSON" --vault River --output /tmp/wr-sa.json
# Then point WR_SERVICE_ACCOUNT_FILE at /tmp/wr-sa.json for the duration of the run.
WR_SERVICE_ACCOUNT_FILE=/tmp/wr-service-account.json
