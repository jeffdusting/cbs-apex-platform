# Gmail OAuth
GMAIL_CREDENTIALS_SECRET=gmail-oauth-token
GMAIL_USER_EMAIL=jeff.dusting@gmail.com

# Microsoft Graph
MS_GRAPH_CLIENT_ID_SECRET=ms-graph-client-id
MS_GRAPH_CLIENT_SECRET_SECRET=ms-graph-client-secret
MS_GRAPH_TENANT_ID_SECRET=ms-graph-tenant-id
MS_TARGET_EMAIL=jeff@cbs.com.au

# Anthropic
ANTHROPIC_API_KEY_SECRET=anthropic-api-key

# Google Cloud Storage bucket for processed email IDs
GCS_BUCKET=flight-calendar-sync-state
GCS_PROCESSED_FILE=processed_email_ids.json

# For local development only (set these directly, not via Secret Manager)
# GMAIL_TOKEN_JSON=<contents of token.json>
# MS_GRAPH_CLIENT_ID=<azure app client id>
# MS_GRAPH_CLIENT_SECRET=<azure app client secret>
# MS_GRAPH_TENANT_ID=<azure tenant id>
# ANTHROPIC_API_KEY=<anthropic api key>
